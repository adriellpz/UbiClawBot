# --- Secrets & local env (never commit) ---
.env
.env.*
!.env.example
trello-gateway/.env
.env.cf
.env.droplet
*.local

# --- Upstream OpenClaw source (install separately or use container image only) ---
openclaw-repo/

# --- Config: real runtime config stays local; template + sanitized live copy tracked ---
config/**
!config/.gitkeep
!config/openclaw.example.json
!config/live/
!config/live/**

# --- Workspace: agent/workspace content stays local; only deploy artifacts tracked ---
workspace/**
!workspace/Dockerfile.gog
!workspace/docker-compose.droplet.yml

# --- Bundles & binaries ---
do-droplet-bundle/
openclaw-droplet-bundle.zip
bin/
!runtime/cheryl/wiki-maintainer/bin/
!runtime/cheryl/wiki-maintainer/bin/**
node_modules/

# --- OS / tooling ---
.DS_Store
Thumbs.db
