# Copy to `.env` and fill in. Used by `workspace/docker-compose.droplet.yml` on build/deploy.
#
# Pin OpenClaw here — this is your versioned dependency (bump when upstream releases).
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.23

# Paths on the host that mount into the container (adjust for your machine or droplet).
# OPENCLAW_CONFIG_DIR=/path/to/.openclaw
# OPENCLAW_AGENT_VAULT_DIR=/path/to/agent-vault  # Obsidian-synced agent workspaces (ubi/, cheryl/, marcos/, wiki/)
# OPENCLAW_AGENT_RUNTIME_DIR=/path/to/agent-runtime  # droplet-only scripts, node_modules, trello_bridge (not synced)

OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_CONFIG_DIR=/home/deploy/openclaw/data/config
OPENCLAW_AGENT_VAULT_DIR=/home/deploy/openclaw/data/agent-vault
OPENCLAW_AGENT_RUNTIME_DIR=/home/deploy/openclaw/data/agent-runtime

# Trello bridge secrets (keep only in server-side `.env`, never commit real values)
# Agents reach Trello via the isolated gateway — not raw API tokens in openclaw-gateway.
TRELLO_GATEWAY_URL=http://trello-gateway:18792
TRELLO_GATEWAY_KEY=REPLACE_ME_MATCH_GATEWAY_ENV
TRELLO_GATEWAY_AGENT_ID=main
TRELLO_BOARD_ID=REPLACE_ME
# TRELLO_BRIDGE_TOKEN=REPLACE_ME_RANDOM_TOKEN
# TRELLO_APP_SECRET=REPLACE_ME_TRELLO_WEBHOOK_SECRET
# TRELLO_CALLBACK_URL=https://ai.sonofwolf.org/trello?token=REPLACE_ME_RANDOM_TOKEN

# Optional temporary fallback for local/manual bridge runs only.
# Keep real values out of the main droplet `.env`; production bridge should use TRELLO_GATEWAY_* above.
# TRELLO_API_KEY=REPLACE_ME
# TRELLO_API_TOKEN=REPLACE_ME

# GitHub — pass a PAT into the gateway container so `gh` / git HTTPS work (OpenClaw loads compose env first).
# Prefer fine-grained token scoped to the repos you need, or classic PAT with repo scope.
# Set one or both; many tools accept either (see docs/help/environment.md).
# GITHUB_TOKEN=
# GH_TOKEN=

# Netlify — personal access token for Netlify CLI / MCP inside OpenClaw containers.
# Only set this in the real server-side `.env` on the droplet, never commit real values.
# NETLIFY_AUTH_TOKEN=

# GitHub PR webhook intake -> Trello review queue (server-side only).
# Set this to the same value as the GitHub webhook secret.
# GITHUB_PR_WEBHOOK_SECRET=
# Optional sidecar listen port (must match Caddy reverse_proxy upstream).
# GITHUB_PR_BRIDGE_PORT=19091
# Optional request body cap in bytes (default 1048576).
# GITHUB_PR_MAX_BODY_BYTES=1048576
# Trello board/list for PR review intake.
# TRELLO_BOARD_ID=sKapJDvB
# TRELLO_INTAKE_LIST_ID=
# Comma-separated historical/done list names ignored during dedupe (default: Done).
# TRELLO_DONE_LIST_NAMES=Done
# Optional OpenClaw wake hook (recommended so review item is immediately actionable).
# OPENCLAW_HOOK_URL=https://ai.sonofwolf.org/hooks/agent
# OPENCLAW_HOOK_TOKEN=
# OPENCLAW_HOOK_AGENT_ID=main
# OPENCLAW_HOOK_SESSION_PREFIX=hook:github-pr:

# Optional: gog / Gmail watch (see compose environment section)
# GOG_KEYRING_BACKEND=file
# GOG_KEYRING_PASSWORD=
# GOG_ACCOUNT=
# GOOGLE_CALENDAR_ID=adriellpz@gmail.com

# Trello routines service (repo-owned scheduled job runtime).
# TRELLO_ROUTINES_LOOKAHEAD_DAYS=14
# TRELLO_ROUTINES_INTERVAL_SECONDS=21600
# TRELLO_ROUTINES_HOST_STATE_DIR=/home/deploy/openclaw/data/trello-routines
# TRELLO_ROUTINES_HEALTH_MAX_AGE_SECONDS=90000

# Trello webhook pipeline (repo-owned bridge / queue worker runtime).
# TRELLO_PIPELINE_HOST_STATE_DIR=/home/deploy/openclaw/data/trello-pipeline
# TRELLO_PIPELINE_STATE_DIR=/var/lib/trello-pipeline
