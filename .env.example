# Copy to `.env` and fill in. Used by `workspace/docker-compose.droplet.yml` on build/deploy.
#
# Pin OpenClaw here — this is your versioned dependency (bump when upstream releases).
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.23

# Paths on the host that mount into the container (adjust for your machine or droplet).
# OPENCLAW_CONFIG_DIR=/path/to/.openclaw
# OPENCLAW_WORKSPACE_DIR=/path/to/workspace

OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_BIND=lan
OPENCLAW_CONFIG_DIR=/home/deploy/openclaw/data/config
OPENCLAW_WORKSPACE_DIR=/home/deploy/openclaw/data/workspace

# Trello bridge secrets (keep only in server-side `.env`, never commit real values)
TRELLO_API_KEY=REPLACE_ME
TRELLO_API_TOKEN=REPLACE_ME

# GitHub — pass a PAT into the gateway container so `gh` / git HTTPS work (OpenClaw loads compose env first).
# Prefer fine-grained token scoped to the repos you need, or classic PAT with repo scope.
# Set one or both; many tools accept either (see docs/help/environment.md).
# GITHUB_TOKEN=
# GH_TOKEN=

# Netlify — personal access token for Netlify CLI / MCP inside OpenClaw containers.
# Only set this in the real server-side `.env` on the droplet, never commit real values.
# NETLIFY_AUTH_TOKEN=

# Optional: gog / Gmail watch (see compose environment section)
# GOG_KEYRING_BACKEND=file
# GOG_KEYRING_PASSWORD=
# GOG_ACCOUNT=
