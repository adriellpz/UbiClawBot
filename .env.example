# Copy to `.env` and fill in. Used by `workspace/docker-compose.droplet.yml` on build/deploy.
#
# Pin OpenClaw here — this is your versioned dependency (bump when upstream releases).
OPENCLAW_IMAGE=ghcr.io/openclaw/openclaw:2026.4.23

# Paths on the host that mount into the container (adjust for your machine or droplet).
# OPENCLAW_CONFIG_DIR=/path/to/.openclaw
# OPENCLAW_WORKSPACE_DIR=/path/to/workspace

OPENCLAW_GATEWAY_TOKEN=
OPENCLAW_GATEWAY_BIND=lan

# Optional: gog / Gmail watch (see compose environment section)
# GOG_KEYRING_BACKEND=file
# GOG_KEYRING_PASSWORD=
# GOG_ACCOUNT=
