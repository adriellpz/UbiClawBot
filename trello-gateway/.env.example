# Copy to trello-gateway/.env on the droplet (never commit real values).
# CI deploy copies tracked files only — it must not overwrite an existing .env.

TRELLO_API_KEY=REPLACE_ME
TRELLO_API_TOKEN=REPLACE_ME
TRELLO_BOARD_ID=REPLACE_ME

# Per-agent Trello identities for comment authorship (optional but recommended in prod).
# TRELLO_API_KEY_MARCOS=REPLACE_ME
# TRELLO_API_TOKEN_MARCOS=REPLACE_ME
# TRELLO_API_KEY_SCHEDULER=REPLACE_ME
# TRELLO_API_TOKEN_SCHEDULER=REPLACE_ME
# TRELLO_API_KEY_SYSTEM=REPLACE_ME
# TRELLO_API_TOKEN_SYSTEM=REPLACE_ME

# Shared secret — must match TRELLO_GATEWAY_KEY in /home/deploy/openclaw/.env
GATEWAY_KEY=REPLACE_ME_LONG_RANDOM

PORT=18792
BIND=0.0.0.0

TRANSITION_MATRIX=/app/trello_transition_matrix.csv
GATEWAY_LOG=/app/gateway.log

# Set MOCK_MODE=true for local smoke tests without Trello credentials.
# MOCK_MODE=false
