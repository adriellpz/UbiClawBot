{
  "version": 1,
  "dropletRoot": "/home/deploy/openclaw",
  "revisionFile": "deployed-revision.json",
  "pathFilters": [
    "workspace/**",
    "github-pr-bridge/**",
    "trello-routines/**",
    "trello-pipeline/**",
    "trello-gateway/**",
    "shared/**",
    "scripts/manual/**",
    "scripts/backup-droplet.sh",
    "scripts/deploy-droplet-remote.sh",
    "scripts/monitor-github-pr-bridge.sh",
    "scripts/sync-live-config.sh",
    "scripts/sync-live-config.mjs",
    "scripts/sanitize-live-config.mjs",
    "config/live/**",
    "deploy/**",
    "runtime/cheryl/**",
    "Caddyfile.droplet",
    ".github/workflows/deploy-droplet.yml"
  ],
  "copyBundles": [
    {
      "id": "workspace",
      "scpSource": "workspace/Dockerfile.gog,workspace/docker-compose.droplet.yml",
      "installMarkers": [
        ".deploy-tmp/Dockerfile.gog",
        ".deploy-tmp/docker-compose.droplet.yml"
      ]
    },
    {
      "id": "caddyfile",
      "scpSource": "Caddyfile.droplet",
      "installMarkers": [".deploy-tmp-root/Caddyfile.droplet"]
    },
    {
      "id": "github-pr-bridge",
      "scpSource": "github-pr-bridge/*",
      "installMarkers": [
        "mkdir -p \"${OPENCLAW_ROOT}/github-pr-bridge\"",
        ".deploy-tmp-github-pr-bridge/github-pr-bridge/"
      ]
    },
    {
      "id": "trello-routines",
      "scpSource": "trello-routines/*",
      "installMarkers": [
        "mkdir -p \"${OPENCLAW_ROOT}/trello-routines\"",
        ".deploy-tmp-trello-routines/trello-routines/"
      ]
    },
    {
      "id": "trello-pipeline",
      "scpSource": "trello-pipeline/*",
      "installMarkers": [
        "mkdir -p \"${OPENCLAW_ROOT}/trello-pipeline\"",
        ".deploy-tmp-trello-pipeline/trello-pipeline/"
      ]
    },
    {
      "id": "shared",
      "scpSource": "shared/*",
      "installMarkers": [
        "mkdir -p \"${OPENCLAW_ROOT}/shared\"",
        ".deploy-tmp-shared/shared/"
      ]
    },
    {
      "id": "scripts-manual",
      "scpSource": "scripts/manual/*",
      "installMarkers": [
        "mkdir -p \"${OPENCLAW_ROOT}/scripts/manual\"",
        ".deploy-tmp-scripts-manual/scripts/manual/"
      ]
    },
    {
      "id": "trello-gateway",
      "scpSource": "trello-gateway/*",
      "installMarkers": [
        "mkdir -p \"${OPENCLAW_ROOT}/trello-gateway\"",
        ".deploy-tmp-trello-gateway/trello-gateway/$f"
      ]
    },
    {
      "id": "deploy-manifest",
      "scpSource": "deploy/manifest.json",
      "installMarkers": [
        "mkdir -p \"${OPENCLAW_ROOT}/deploy\"",
        ".deploy-tmp-deploy/deploy/manifest.json"
      ]
    },
    {
      "id": "live-config",
      "scpSource": "config/live/**",
      "installMarkers": [
        "mkdir -p \"${OPENCLAW_ROOT}/config/live\"",
        ".deploy-tmp-live-config/config/live/."
      ]
    },
    {
      "id": "ops-scripts",
      "scpSource": "scripts/backup-droplet.sh,scripts/deploy-droplet-remote.sh,scripts/monitor-github-pr-bridge.sh,scripts/sync-live-config.sh,scripts/sync-live-config.mjs,scripts/sanitize-live-config.mjs",
      "installMarkers": [
        ".deploy-tmp-ops-scripts/scripts/backup-droplet.sh",
        ".deploy-tmp-ops-scripts/scripts/deploy-droplet-remote.sh",
        ".deploy-tmp-ops-scripts/scripts/monitor-github-pr-bridge.sh",
        ".deploy-tmp-ops-scripts/scripts/sync-live-config.sh",
        ".deploy-tmp-ops-scripts/scripts/sync-live-config.mjs",
        ".deploy-tmp-ops-scripts/scripts/sanitize-live-config.mjs"
      ]
    },
    {
      "id": "cheryl-wiki-maintainer",
      "scpSource": "runtime/cheryl/wiki-maintainer/**",
      "installMarkers": [
        "mkdir -p \"${OPENCLAW_ROOT}/data/agent-runtime/cheryl/wiki-maintainer\"",
        ".deploy-tmp-cheryl-wiki-maintainer/runtime/cheryl/wiki-maintainer/."
      ]
    }
  ],
  "gatewayFiles": [
    "Dockerfile",
    "deploy.sh",
    "trello_card_contract.mjs",
    "trello_gateway.mjs",
    "trello_transition_matrix.csv",
    ".env.example"
  ],
  "composeRecreateServices": [
    "openclaw-gateway",
    "openclaw-cli",
    "trello-bridge",
    "github-pr-bridge",
    "trello-gateway",
    "trello-queue-worker",
    "trello-routines"
  ],
  "smokeChecks": {
    "requiredFiles": [
      "scripts/manual/backfill_routine_card_due.mjs",
      "scripts/manual/backfill_calendar_links_to_description.mjs",
      "trello-routines/ensure_routines.mjs",
      "trello-pipeline/server.mjs",
      "shared/pr_review_card.mjs",
      "trello-gateway/trello_gateway.mjs",
      "github-pr-bridge/server.mjs",
      "docker-compose.yml",
      "deploy/manifest.json",
      "config/live/openclaw.json",
      "scripts/sync-live-config.sh",
      "scripts/monitor-github-pr-bridge.sh",
      "data/agent-runtime/cheryl/wiki-maintainer/bin/wiki-log-preflight.mjs"
    ],
    "httpEndpoints": [
      {
        "id": "trello-gateway",
        "url": "http://127.0.0.1:18792/healthz"
      },
      {
        "id": "github-pr-bridge",
        "url": "http://127.0.0.1:${GITHUB_PR_BRIDGE_PORT:-19091}/healthz"
      },
      {
        "id": "trello-bridge",
        "url": "http://127.0.0.1:18990/health"
      }
    ]
  }
}
